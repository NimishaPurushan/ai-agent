# --- OpenAI ---
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# --- OpenSearch ---
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=chatbot-docs
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MCP ---
# Path to a JSON file describing MCP servers. See mcp_servers.example.json.
MCP_SERVERS_CONFIG=./mcp_servers.json

# --- LangSmith observability (optional) ---
# Create a project and API key at https://smith.langchain.com/
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-agent-dev
# For regional or multi-workspace deployments, set these as needed:
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=
# LANGSMITH_TRACING_SAMPLING_RATE=1.0
# Set either to true if prompts, retrieval content, or outputs may contain PII.
# LANGSMITH_HIDE_INPUTS=false
# LANGSMITH_HIDE_OUTPUTS=false

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Email/SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your-email@gmail.com
